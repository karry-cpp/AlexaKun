# --- Wake-word detection (Vosk) --------------------------------------------
KARRY_VOSK_MODEL_PATH=models/vosk-model-small-en-us-0.15
KARRY_WAKE_PHRASES=hey karry,hi karry,hey kari,hey carry
KARRY_WAKE_FUZZY_THRESHOLD=82
KARRY_WAKE_COOLDOWN_SECONDS=2

# --- Microphone -------------------------------------------------------------
KARRY_SAMPLE_RATE=16000
KARRY_MIC_DEVICE_INDEX=

# --- Command capture (VAD) --------------------------------------------------
KARRY_COMMAND_MAX_SECONDS=12
KARRY_COMMAND_SILENCE_MS=900
KARRY_VAD_AGGRESSIVENESS=2

# --- Command STT (faster-whisper) ------------------------------------------
# Options: tiny, base, small, medium, large-v3, large-v3-turbo
# large-v3-turbo is a distilled speed-optimized version of large-v3 with
# essentially the same Indian-accent + Hindi accuracy but ~4x faster on CPU
# and ~1.6 GB instead of ~3 GB. Recommended default.
KARRY_WHISPER_MODEL=large-v3-turbo
KARRY_WHISPER_COMPUTE_TYPE=int8
KARRY_WHISPER_DEVICE=cpu
KARRY_WHISPER_LANGUAGE=
KARRY_WHISPER_MODEL_DIR=models/whisper

# --- Intent resolution (Ollama) --------------------------------------------
KARRY_OLLAMA_URL=http://127.0.0.1:11434
KARRY_OLLAMA_MODEL=qwen2.5:3b-instruct
KARRY_OLLAMA_TIMEOUT_SECONDS=10
KARRY_OLLAMA_ENABLED=true

# --- Text-to-speech --------------------------------------------------------
KARRY_TTS_ENABLED=true
KARRY_TTS_VOICE_EN=en-IN-NeerjaNeural
KARRY_TTS_VOICE_HI=hi-IN-SwaraNeural
KARRY_TTS_RATE=+0%

# --- Safety ----------------------------------------------------------------
KARRY_CONFIRM_DESTRUCTIVE=true
KARRY_DESTRUCTIVE_TIMEOUT_SECONDS=6

# --- Logging ---------------------------------------------------------------
KARRY_LOG_LEVEL=INFO
