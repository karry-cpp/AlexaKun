# --- Wake-word detection (Vosk) --------------------------------------------
JIMMY_VOSK_MODEL_PATH=models/vosk-model-small-en-in-0.4
# 'Jimmy' transcribes far more reliably than 'Jimmy' on accented English.
# The extra variants catch common mis-transcriptions from Vosk's small model.
JIMMY_WAKE_PHRASES=hey jimmy,hi jimmy,hey jim,hey jimmi,hey jimi,he jimmy
JIMMY_WAKE_FUZZY_THRESHOLD=78
JIMMY_WAKE_COOLDOWN_SECONDS=2

# --- Microphone -------------------------------------------------------------
JIMMY_SAMPLE_RATE=16000
JIMMY_MIC_DEVICE_INDEX=

# --- Command capture (VAD) --------------------------------------------------
JIMMY_COMMAND_MAX_SECONDS=12
JIMMY_COMMAND_SILENCE_MS=900
JIMMY_VAD_AGGRESSIVENESS=2

# --- Command STT (faster-whisper) ------------------------------------------
# Options: tiny, base, small, medium, large-v3, large-v3-turbo
# large-v3-turbo is a distilled speed-optimized version of large-v3 with
# essentially the same Indian-accent + Hindi accuracy but ~4x faster on CPU
# and ~1.6 GB instead of ~3 GB. Recommended default.
JIMMY_WHISPER_MODEL=large-v3-turbo
JIMMY_WHISPER_COMPUTE_TYPE=int8
JIMMY_WHISPER_DEVICE=cpu
JIMMY_WHISPER_LANGUAGE=
JIMMY_WHISPER_MODEL_DIR=models/whisper

# --- Intent resolution (Ollama) --------------------------------------------
JIMMY_OLLAMA_URL=http://127.0.0.1:11434
JIMMY_OLLAMA_MODEL=qwen2.5:3b-instruct
JIMMY_OLLAMA_TIMEOUT_SECONDS=10
JIMMY_OLLAMA_ENABLED=true

# --- Text-to-speech --------------------------------------------------------
JIMMY_TTS_ENABLED=true
JIMMY_TTS_VOICE_EN=en-US-GuyNeural
JIMMY_TTS_VOICE_HI=hi-IN-MadhurNeural
JIMMY_TTS_RATE=+0%

# --- Safety ----------------------------------------------------------------
JIMMY_CONFIRM_DESTRUCTIVE=true
JIMMY_DESTRUCTIVE_TIMEOUT_SECONDS=6

# --- Logging ---------------------------------------------------------------
JIMMY_LOG_LEVEL=INFO
